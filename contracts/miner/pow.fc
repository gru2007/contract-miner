;; Get methods

int seqno() method_id {
  return get_data().begin_parse().preload_uint(32);
}

;; GRM-compatible get-method: (seed, pow_complexity, reward_amount, target_delta)
(int, int, int, int) get_pow_params() method_id {
  storage::load();
  return (storage::seed, storage::pow_complexity, storage::reward_amount, storage::target_delta);
}

slice get_jetton_wallet_address() method_id {
  var ds = get_data().begin_parse();
  ds~load_msg_addr(); ;; owner_addr
  return ds~load_msg_addr();
}

slice get_jetton_minter_address() method_id {
  var ds = get_data().begin_parse();
  ds~load_msg_addr(); ;; owner_addr
  return ds~load_msg_addr();
}

int get_reward_amount() method_id {
  storage::load();
  return storage::reward_amount;
}

(int, int, int, int, int, int) get_mining_config() method_id {
  storage::load();
  return (storage::seed, storage::pow_complexity, storage::target_delta, storage::min_cpl, storage::max_cpl, storage::reward_amount);
}

(slice, slice, int, int, int, int, int, int, int) get_miner_data() method_id {
  storage::load();
  return (storage::owner_addr, storage::jetton_minter_addr, storage::seed, storage::pow_complexity, storage::last_success, storage::target_delta, storage::min_cpl, storage::max_cpl, storage::reward_amount);
}
