() handle_int::transfer_notification(slice sender_addr) impure inline_ref {

    int empty_jwall? = extlib::slice_data_equal?(
        storage::jetton_minter_addr, 
        extlib::addr_none()
    );

    if (empty_jwall?) {
        storage::jetton_minter_addr = sender_addr;
        storage::exit_save();
    }

    throw(err::jis_set());
}
